# Local state, secrets, caches — never committed.
.claude/
.venv/
# secrets (e.g. CONSTRUCT_TELEGRAM_TOKEN) — gitignore has NO inline comments, so the
# comment must be on its own line or the pattern becomes a literal ".env   # ..." and fails.
.env
.env.*
dev_inbox/
logs/
*.egg-info/
__pycache__/
.pytest_cache/

# Generated hidden bibles — runtime artifacts (the authoring side of the firewall).
generated/

# SCENE-IMAGERY: generated location image assets (runtime, regenerable from the
# per-scenario prompt manifests at worlds/<scenario>.images.json — themselves ignored
# by the worlds/* rule below).
images/

# Built/runtime worlds are regenerable from examples/ source (the firewall), so they
# are ignored — EXCEPT the shipped demo scenario `anchor` (its pristine build + meta),
# so a fresh clone has a good story ready to play. Per-player play slots, other test/
# built worlds (incl. live_* and worlds/_retired/), backups, and transport state
# (worlds/.construct/) all stay ignored. The committed source fixture lives in
# examples/ (Kernos 063 B.2).
*.world
worlds/*
!worlds/anchor.world
!worlds/anchor.meta.json
